<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>我的小宠物</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Comic Sans MS', 'Microsoft YaHei', sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            max-width: 400px;
            width: 100%;
        }

        h1 {
            text-align: center;
            color: #ff6b6b;
            margin-bottom: 20px;
        }

        .setup-screen {
            text-align: center;
        }

        .setup-screen h2 {
            color: #4ecdc4;
            margin-bottom: 20px;
        }

        .name-input {
            width: 100%;
            padding: 12px;
            border: 2px solid #4ecdc4;
            border-radius: 10px;
            font-size: 16px;
            margin-bottom: 20px;
            text-align: center;
        }

        .pet-select {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-bottom: 20px;
        }

        .pet-option {
            width: 100px;
            height: 100px;
            border: 3px solid #ddd;
            border-radius: 15px;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            background: #f9f9f9;
        }

        .pet-option:hover {
            border-color: #4ecdc4;
            transform: scale(1.05);
        }

        .pet-option.selected {
            border-color: #ff6b6b;
            background: #fff0f0;
        }

        .pet-option span {
            font-size: 40px;
            margin-bottom: 5px;
        }

        .pet-option p {
            color: #666;
            font-size: 14px;
        }

        .start-btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(45deg, #ff6b6b, #ffa502);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 18px;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .start-btn:hover {
            transform: scale(1.02);
        }

        .game-screen {
            display: none;
        }

        .pet-display {
            text-align: center;
            position: relative;
            margin: 20px 0;
            min-height: 200px;
        }

        .pet-name {
            font-size: 24px;
            color: #333;
            margin-bottom: 10px;
        }

        .pet-emoji {
            font-size: 100px;
            display: inline-block;
            transition: transform 0.3s;
            cursor: default;
        }

        .pet-emoji.wag {
            animation: wag 0.3s infinite alternate;
        }

        @keyframes wag {
            from { transform: rotate(-10deg); }
            to { transform: rotate(10deg); }
        }

        .pet-emoji.bounce {
            animation: bounce 0.5s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }

        .floating {
            position: absolute;
            font-size: 30px;
            animation: floatUp 1.5s ease-out forwards;
            pointer-events: none;
        }

        @keyframes floatUp {
            0% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
            100% {
                opacity: 0;
                transform: translateY(-100px) scale(1.5);
            }
        }

        .status-bar {
            display: flex;
            justify-content: space-around;
            margin: 20px 0;
            padding: 15px;
            background: #f9f9f9;
            border-radius: 10px;
        }

        .status-item {
            text-align: center;
        }

        .status-label {
            font-size: 14px;
            color: #666;
            margin-bottom: 5px;
        }

        .status-value {
            font-size: 20px;
            font-weight: bold;
        }

        .status-value.fullness {
            color: #ffa502;
        }

        .status-value.mood {
            color: #ff6b6b;
        }

        .action-buttons {
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        .action-btn {
            flex: 1;
            padding: 15px 10px;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
        }

        .action-btn:hover {
            transform: translateY(-3px);
        }

        .action-btn span {
            font-size: 24px;
        }

        .feed-btn {
            background: #ffeaa7;
            color: #d63031;
        }

        .water-btn {
            background: #74b9ff;
            color: #0984e3;
        }

        .play-btn {
            background: #fd79a8;
            color: #e84393;
        }

        .reset-btn {
            width: 100%;
            padding: 10px;
            background: #636e72;
            color: white;
            border: none;
            border-radius: 8px;
            margin-top: 15px;
            cursor: pointer;
        }

        .message {
            text-align: center;
            padding: 10px;
            color: #666;
            font-size: 14px;
            min-height: 30px;
        }

        .pet-info {
            text-align: center;
            color: #666;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🐾 养宠物 🐾</h1>
        
        <div class="setup-screen" id="setupScreen">
            <h2>选择你的小宠物</h2>
            <input type="text" class="name-input" id="petNameInput" placeholder="给宠物起个名字吧~" maxlength="10">
            <div class="pet-select">
                <div class="pet-option selected" data-pet="cat" onclick="selectPet('cat')">
                    <span>🐱</span>
                    <p>小猫咪</p>
                </div>
                <div class="pet-option" data-pet="dog" onclick="selectPet('dog')">
                    <span>🐶</span>
                    <p>小狗狗</p>
                </div>
            </div>
            <button class="start-btn" onclick="startGame()">开始养宠物</button>
        </div>

        <div class="game-screen" id="gameScreen">
            <div class="pet-info">
                <span id="petTypeText"></span>
            </div>
            <div class="pet-display">
                <div class="pet-name" id="petName"></div>
                <div class="pet-emoji" id="petEmoji">🐱</div>
            </div>

            <div class="message" id="message"></div>

            <div class="status-bar">
                <div class="status-item">
                    <div class="status-label">🍖 饱腹度</div>
                    <div class="status-value fullness" id="fullness">100</div>
                </div>
                <div class="status-item">
                    <div class="status-label">💖 心情</div>
                    <div class="status-value mood" id="mood">100</div>
                </div>
            </div>

            <div class="action-buttons">
                <button class="action-btn feed-btn" onclick="feed()">
                    <span>🍖</span>
                    喂食
                </button>
                <button class="action-btn water-btn" onclick="giveWater()">
                    <span>💧</span>
                    喂水
                </button>
                <button class="action-btn play-btn" onclick="play()">
                    <span>🎾</span>
                    陪玩
                </button>
            </div>

            <button class="reset-btn" onclick="resetGame()">🔄 重新开始</button>
        </div>
    </div>

    <script>
        let gameData = {
            hasPet: false,
            petType: 'cat',
            petName: '',
            fullness: 100,
            mood: 100
        };

        const petEmojis = {
            cat: '🐱',
            dog: '🐶'
        };

        // 页面加载时读取数据
        window.onload = function() {
            loadGameData();
        };

        function selectPet(type) {
            document.querySelectorAll('.pet-option').forEach(opt => {
                opt.classList.remove('selected');
            });
            document.querySelector(`[data-pet="${type}"]`).classList.add('selected');
            gameData.petType = type;
        }

        function startGame() {
            const name = document.getElementById('petNameInput').value.trim();
            if (!name) {
                alert('请给你的宠物起个名字~');
                return;
            }
            
            gameData.hasPet = true;
            gameData.petName = name;
            gameData.fullness = 100;
            gameData.mood = 100;
            
            saveGameData();
            showGameScreen();
        }

        function showGameScreen() {
            document.getElementById('setupScreen').style.display = 'none';
            document.getElementById('gameScreen').style.display = 'block';
            
            document.getElementById('petName').textContent = gameData.petName;
            document.getElementById('petEmoji').textContent = petEmojis[gameData.petType];
            document.getElementById('petTypeText').textContent = gameData.petType === 'cat' ? '🐱 小猫咪' : '🐶 小狗狗';
            
            updateStatus();
        }

        function updateStatus() {
            document.getElementById('fullness').textContent = gameData.fullness;
            document.getElementById('mood').textContent = gameData.mood;
        }

        function showFloatingEmoji(emoji) {
            const petDisplay = document.querySelector('.pet-display');
            const floating = document.createElement('div');
            floating.className = 'floating';
            floating.textContent = emoji;
            floating.style.left = Math.random() * 100 + 50 + 'px';
            floating.style.top = '80px';
            petDisplay.appendChild(floating);
            
            setTimeout(() => {
                floating.remove();
            }, 1500);
        }

        function animatePet(type) {
            const pet = document.getElementById('petEmoji');
            pet.classList.remove('wag', 'bounce');
            
            void pet.offsetWidth;
            
            if (type === 'play') {
                pet.classList.add('bounce');
            } else {
                pet.classList.add('wag');
            }
            
            setTimeout(() => {
                pet.classList.remove('wag', 'bounce');
            }, 1500);
        }

        function feed() {
            if (gameData.fullness >= 100) {
                showMessage('已经吃饱饱啦！');
                return;
            }
            
            gameData.fullness = Math.min(100, gameData.fullness + 20);
            gameData.mood = Math.min(100, gameData.mood + 5);
            
            animatePet('feed');
            showFloatingEmoji('🍖');
            showFloatingEmoji('❤️');
            showMessage('好吃！' + gameData.petName + '开心地吃了起来~');
            
            saveGameData();
            updateStatus();
        }

        function giveWater() {
            if (gameData.fullness >= 100) {
                showMessage('不渴不渴~');
                return;
            }
            
            gameData.fullness = Math.min(100, gameData.fullness + 10);
            
            animatePet('water');
            showFloatingEmoji('💧');
            showMessage('咕噜咕噜~好喝！');
            
            saveGameData();
            updateStatus();
        }

        function play() {
            if (gameData.fullness < 30) {
                showMessage('好饿呀，先吃点东西吧~');
                return;
            }
            
            if (gameData.mood >= 100) {
                showMessage('心情已经很好了！');
                return;
            }
            
            gameData.mood = Math.min(100, gameData.mood + 25);
            gameData.fullness = Math.max(0, gameData.fullness - 10);
            
            animatePet('play');
            showFloatingEmoji('⭐');
            showFloatingEmoji('❤️');
            showFloatingEmoji('🎵');
            showMessage('太好玩了！' + gameData.petName + '开心地摇起了尾巴~');
            
            saveGameData();
            updateStatus();
        }

        function showMessage(msg) {
            document.getElementById('message').textContent = msg;
        }

        function saveGameData() {
            localStorage.setItem('petGameData', JSON.stringify(gameData));
        }

        function loadGameData() {
            const saved = localStorage.getItem('petGameData');
            if (saved) {
                gameData = JSON.parse(saved);
                if (gameData.hasPet) {
                    showGameScreen();
                }
            }
        }

        function resetGame() {
            if (confirm('确定要重新开始吗？')) {
                gameData = {
                    hasPet: false,
                    petType: 'cat',
                    petName: '',
                    fullness: 100,
                    mood: 100
                };
                localStorage.removeItem('petGameData');
                document.getElementById('gameScreen').style.display = 'none';
                document.getElementById('setupScreen').style.display = 'block';
                document.getElementById('petNameInput').value = '';
                selectPet('cat');
            }
        }

        // 自动减少饱腹度和心情
        setInterval(() => {
            if (gameData.hasPet) {
                gameData.fullness = Math.max(0, gameData.fullness - 1);
                gameData.mood = Math.max(0, gameData.mood - 1);
                saveGameData();
                updateStatus();
                
                if (gameData.fullness === 0) {
                    showMessage('肚子好饿啊...');
                } else if (gameData.mood === 0) {
                    showMessage('好无聊啊，快来陪我玩~');
                }
            }
        }, 30000);
    </script>
</body>
</html>
